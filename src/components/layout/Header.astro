---
import { CloudCheck, LogIn } from "lucide-astro";
import Logo from "@/assets/Logo.svg";
import LoginButton from "@/components/common/LoginButton.tsx";
import { SELECTABLE_TERMS, SELECTABLE_YEARS } from "@/constants/time.ts";
import { DEFAULT_LANG, LANGUAGES } from "@/lib/translation/ui.ts";
import { createTranslationHelper } from "@/lib/translation/utils.ts";

const lang = Astro.locals.lang || DEFAULT_LANG;
const { t, l } = createTranslationHelper(lang);

const { user, selectedYear, selectedTerm, dbError } = Astro.locals;
const isLoggedIn = !!user;

const currentUrl = Astro.url.href;
const baseUrl =
	"https://docs.google.com/forms/d/e/1FAIpQLSe_76F-MOJhkuG0346otCkCn3KlSqTTHXulhTNGNozNRXUqdg/viewform";
const formUrl = `${baseUrl}?usp=pp_url&entry.1846364970=${encodeURIComponent(currentUrl)}`;
---

<header
	class="navbar min-h-0 h-12 lg:h-16 sticky top-0 z-50 bg-base-100 shadow-sm"
>
	<div class="navbar-start">
		<a class="btn btn-ghost text-xl flex gap-2 px-2" href={l("/")}>
			<Logo width={24} height={24} />
			<h1 class="hidden sm:inline">{t("site.title")}</h1>
		</a>
	</div>
	<div class="navbar-center flex gap-2">
		<label class="flex gap-1 items-center">
			<select
				id="year-select"
				class="select select-bordered select-sm md:select-md w-fit font-bold"
				autocomplete="off"
			>
				{
					SELECTABLE_YEARS.map((y) => (
						<option value={y} selected={Number(selectedYear) === y}>
							{y}
						</option>
					))
				}
			</select>
			<select
				id="term-select"
				class="select select-bordered select-sm md:select-md w-fit font-bold"
				autocomplete="off"
			>
				{
					SELECTABLE_TERMS.map((termObj) => (
						<option value={termObj} selected={selectedTerm === termObj}>
							{t(`term.${termObj}` as any) || termObj}
						</option>
					))
				}
			</select>
		</label>
	</div>
	<nav class="navbar-end">
		{
			!dbError && (
				<div class="dropdown dropdown-end" id="user-dropdown">
					<button
						type="button"
						class="btn btn-circle w-10 h-10 shadow-inner ring-1 ring-base-content/10"
						id="dropdown-button"
					>
						{user ? (
							<CloudCheck class="text-success pointer-events-none" size={20} />
						) : (
							<LogIn class="pointer-events-none" size={20} />
						)}
					</button>
					<nav class="dropdown-content w-68 p-4 mt-2 shadow-xl bg-base-100 rounded-xl border border-base-200 z-50">
						<ul class="flex flex-col items-center gap-4 w-full">
							<li class="w-full text-center">
								<h3 class="font-bold text-sm">
									{isLoggedIn ? t("header.synced") : t("header.login_to_sync")}
								</h3>
							</li>
							<li class="w-full">
								<LoginButton client:load isLoggedIn={isLoggedIn} lang={lang} />
							</li>
							<li class="w-full -my-2">
								<div class="divider opacity-20 w-full my-0" />
							</li>
							<li class="w-full">
								<nav class="w-full join border border-base-300">
									{LANGUAGES.map((l) => (
										<button
											class={`join-item btn btn-sm flex-1 ${lang === l ? "btn-active btn-neutral" : "btn-ghost"}`}
											data-lang-switch={l}
										>
											{l.toUpperCase()}
										</button>
									))}
								</nav>
							</li>
							<li class="w-full py-1">
								<a
									target="_blank"
									href={formUrl}
									class="flex flex-col items-center link text-base-content/60"
								>
									<span class="text-[11px]">{t("header.support")}</span>
								</a>
							</li>
						</ul>
					</nav>
				</div>
			)
		}
	</nav>
</header>

<script>
	/**
	 * 現在のURLのクエリパラメータを維持したまま
	 * Year と Term だけを書き換えて遷移する
	 */
	const updateYearTerm = () => {
		const yearSelect = document.getElementById(
			"year-select",
		) as unknown as HTMLSelectElement;
		const termSelect = document.getElementById(
			"term-select",
		) as unknown as HTMLSelectElement;

		if (!yearSelect || !termSelect) return;

		const url = new URL(window.location.href);
		url.searchParams.set("year", yearSelect.value);
		url.searchParams.set("term", termSelect.value);

		// ページネーションがある場合、年度が変わったら1ページ目に戻す
		if (url.searchParams.has("page")) {
			url.searchParams.set("page", "1");
		}

		window.location.assign(url.toString());
	};

	// イベントリスナーの登録
	document
		.getElementById("year-select")
		?.addEventListener("change", updateYearTerm);
	document
		.getElementById("term-select")
		?.addEventListener("change", updateYearTerm);

	// --- 言語切り替えロジック ---
	document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
		btn.addEventListener("click", (e) => {
			const targetLang = (e.currentTarget as HTMLButtonElement).dataset.langSwitch;
			if (!targetLang) return;

			// Cookieをセット
			document.cookie = `lang=${targetLang}; path=/; max-age=${60 * 60 * 24 * 365}`;

			// ページをリロード（middlewareのリダイレクトロジックが発動する）
			window.location.reload();
		});
	});
	// --- ドロップダウンの開閉 ---
	const dropdown = document.getElementById("user-dropdown");
	const button = document.getElementById("dropdown-button");

	if (dropdown && button) {
		button.addEventListener("click", (e) => {
			e.stopPropagation();
			const isOpen = dropdown.classList.contains("dropdown-open");

			if (isOpen) {
				dropdown.classList.remove("dropdown-open");
				(e.currentTarget as HTMLElement).blur();
			} else {
				dropdown.classList.add("dropdown-open");
			}
		});

		document.addEventListener("click", (e) => {
			if (!dropdown.contains(e.target as Node)) {
				dropdown.classList.remove("dropdown-open");
			}
		});
	}
</script>
