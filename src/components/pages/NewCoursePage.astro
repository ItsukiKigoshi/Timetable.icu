---
// 新規コース追加Buttonを押したらこのページに飛ばされる
// /timetable/new.astro
import Layout from "@/components/layout/Layout.astro";
import CourseEditor from "@/components/timetable/CourseEditor";
import { PERIODS, SELECTABLE_DAYS } from "@/constants/time.ts";
import { createTranslationHelper } from "@/lib/translation/utils.ts";

const { lang, user, selectedYear, selectedTerm } = Astro.locals;
const { t } = createTranslationHelper(lang);

const slotsParam = Astro.url.searchParams.get("slots"); // "Tue-4"
let initialData = null;

if (slotsParam) {
	const [day, pLabel] = slotsParam.split("-");
	const periodData = PERIODS.find((p) => p.label === pLabel);

	if (day && periodData) {
		initialData = {
			title: "",
			units: 0,
			year: selectedYear,
			term: selectedTerm,
			instructor: "",
			room: "",
			memo: "",
			schedules: [
				{
					dayOfWeek: day as (typeof SELECTABLE_DAYS)[number],
					period: pLabel,
					startTime: periodData.start,
					endTime: periodData.end,
				},
			],
		};
	}
}
---

<Layout title=`${t('custom.create')} | ${t('site.title')}`>
	<div class="max-w-2xl mx-auto p-4 flex flex-col">
		<CourseEditor
			client:load
			mode="create"
			lang={lang}
			user={user}
			selectedYear={selectedYear}
			selectedTerm={selectedTerm}
			initialData={initialData}
		/>
	</div>
</Layout>
